# ============================================================================
#  Copy to .env and fill in. NEVER commit .env. (.env is gitignored.)
# ============================================================================

# --- OpenAI (all model calls) --------------------------------------------
# Generate the key at platform.openai.com -> API keys.
# Override BASE_URL/MODEL to point at any OpenAI-compatible provider.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# --- Daytona (sandbox eval runner) ---------------------------------------
# Generate the key in the Daytona Dashboard.
DAYTONA_API_KEY=
DAYTONA_TARGET=us                   # or eu
DAYTONA_STUB=0                      # set 1 to score candidates locally if Daytona is blocked

# --- Insforge (backend + audit trail) ------------------------------------
INSFORGE_API_KEY=
INSFORGE_BASE_URL=                  # your project URL from insforge.dev
STORE_BACKEND=memory                # "memory" (default, no setup) or "insforge"

# --- Kalibr (orchestration layer) ----------------------------------------
KALIBR_API_KEY=                     # if SDK-based; else loop runs natively (open decision #3)

# --- Apify (live trend ingestion) ----------------------------------------
# API token from Apify Console -> Settings -> Integrations.
APIFY_API_TOKEN=
APIFY_INSTAGRAM_ACTOR=apify/instagram-search-scraper
