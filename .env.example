# ============================================================================
#  Copy to .env and fill in. NEVER commit .env. (.env is gitignored.)
# ============================================================================

# --- NEAR AI Cloud (model calls + attestation) ---------------------------
# Generate the key in the NEAR AI Cloud Dashboard. If unset, the model client runs
# in deterministic offline MOCK mode (the whole demo runs with zero keys).
NEAR_AI_API_KEY=
NEAR_AI_BASE_URL=https://cloud-api.near.ai/v1
NEAR_AI_MODEL=deepseek-ai/DeepSeek-V3.1   # default slug for legacy complete()
# Multi-model NEAR for the Kalibr-routed self-healing loop. A "heal" swaps between these.
NEAR_AI_MODEL_QWEN=Qwen/Qwen3.5-122B-A10B
NEAR_AI_MODEL_DEEPSEEK=deepseek-ai/DeepSeek-V3.1
NEAR_AI_MODEL_GLM=                  # GLM-5 slug unverified — check completions.near.ai/endpoints
NEAR_AI_CHAOS=                      # demo: comma-list of path ids to force-fail, e.g. near-qwen3.5
NEAR_AI_ATTESTATION=stub            # "stub" for MVP; switch to "real" for verifiable receipts

# --- Fallback model provider (so one provider can never block us) --------
LLM_FALLBACK_API_KEY=
LLM_FALLBACK_BASE_URL=https://api.openai.com/v1
LLM_FALLBACK_MODEL=gpt-4o-mini

# --- Daytona (sandbox eval runner) ---------------------------------------
# Generate the key in the Daytona Dashboard.
DAYTONA_API_KEY=
DAYTONA_TARGET=us                   # or eu
DAYTONA_STUB=0                      # set 1 to score candidates locally if Daytona is blocked

# --- Insforge (backend + audit trail) ------------------------------------
INSFORGE_API_KEY=
INSFORGE_BASE_URL=                  # your project URL from insforge.dev
STORE_BACKEND=memory                # "memory" (default, no setup) or "insforge"

# --- Kalibr Intelligence API (decoupled routing + self-healing + learning) ---
# dashboard.kalibr.systems -> settings. Key looks like sk_...; tenant like user_/org_...
# If unset, the Kalibr client runs in deterministic offline MOCK mode.
KALIBR_API_KEY=
KALIBR_TENANT_ID=
KALIBR_BASE_URL=https://kalibr-intelligence.fly.dev

# --- Apify (live trend ingestion) ----------------------------------------
# API token from Apify Console -> Settings -> Integrations. Either name works
# (APIFY_TOKEN preferred per the handoff; APIFY_API_TOKEN kept for back-compat).
# If unset, the Apify client returns deterministic mock trends.
APIFY_TOKEN=
APIFY_API_TOKEN=
APIFY_FACEBOOK_ACTOR=apify~facebook-posts-scraper
APIFY_INSTAGRAM_ACTOR=apify/instagram-search-scraper
